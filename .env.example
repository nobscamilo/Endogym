# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Gemini (backend)
GOOGLE_AI_BACKEND=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_PLATE=gemini-3-flash-preview
# Si activas GOOGLE_AI_BACKEND=vertex, usa gemini-3-pro-preview hasta que Vertex exponga 3.1 oficialmente.
GEMINI_MODEL_COACH=gemini-3.1-pro-preview
GEMINI_FORCE_MOCK=false
GEMINI_FALLBACK_TO_MOCK=true
GEMINI_COACH_MAX_RETRIES=2
GEMINI_COACH_RETRY_BASE_MS=350

# Optional: Vertex AI / GCP backend
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=global
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Local development (set true only for local smoke/dev)
AUTH_DISABLED=true

# Vercel/Next runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_DISABLED=true

# Firebase Client (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
