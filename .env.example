# Firebase Admin (Backend)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Gemini / Google AI (Backend)
GOOGLE_AI_BACKEND=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_PLATE=gemini-2.5-flash
GEMINI_MODEL_COACH=gemini-2.5-flash
GEMINI_FORCE_MOCK=false
GEMINI_FALLBACK_TO_MOCK=true
GEMINI_COACH_MAX_RETRIES=1
GEMINI_COACH_RETRY_BASE_MS=350
GEMINI_COACH_TIMEOUT_MS=10000

# Persistent Firestore rate limits for costly API operations
PLATE_ANALYSIS_RATE_LIMIT_MAX=10
PLATE_ANALYSIS_RATE_LIMIT_WINDOW_SECONDS=600
WEEKLY_PLAN_RATE_LIMIT_MAX=4
WEEKLY_PLAN_RATE_LIMIT_WINDOW_SECONDS=3600

# Local development (disable Auth for development/smoke test)
AUTH_DISABLED=true

# Vercel/Next runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_DISABLED=true

# Firebase Client (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
